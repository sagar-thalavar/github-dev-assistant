# GitHub Authentication
# Personal Access Token (PAT) with repository, issues, and pull request write scopes
GITHUB_TOKEN=your_github_token_here

# Gemini API Authentication
# API key to access Google's Gemini models
GEMINI_API_KEY=your_gemini_api_key_here

# Default Target Repository (for testing)
# Format: owner/repo-name
TARGET_REPO=sagar-thalavar/ai-lab
